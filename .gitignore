# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# supabase CLI scratch
supabase/.temp/
supabase/.branches/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright MCP artifacts
.playwright-mcp/
plataforma-teste.png

# local-stack native binaries (PostgREST, GoTrue, etc.) — baixados localmente, não versionar
scripts/local-stack/bin/

# hub Windows native binaries (auth.exe, migrations/, Postgres, PostgREST) — empacotados/baixados, não versionar
hub/win/bin/
