# Config do GoTrue (Supabase Auth) nativo, apontando pro MESMO Postgres local
# (porta 54329) e a MESMA JWT secret usada pelo PostgREST.
#
# Uso:
#   set -a; source scripts/local-stack/gotrue.env; set +a
#   scripts/local-stack/bin/auth migrate   # roda as migrations do auth (cria schema auth)
#   scripts/local-stack/bin/auth serve      # sobe a API em 127.0.0.1:9999
#
# OBS: GoTrue conecta via TCP (127.0.0.1:54329). O Postgres nativo deste spike
# escuta em 127.0.0.1 (ver ss -ltnp), então TCP funciona.

GOTRUE_DB_DRIVER=postgres
# search_path=auth -> GoTrue cria/usa objetos no schema auth.
# ASPAS obrigatórias: o '&' do query string quebra o `source` do shell sem elas.
DATABASE_URL="postgres://supabase_auth_admin:authpass@127.0.0.1:54329/exped?search_path=auth&sslmode=disable"

GOTRUE_API_HOST=127.0.0.1
GOTRUE_API_PORT=9999
# URL externa da API (obrigatório pelo GoTrue).
API_EXTERNAL_URL=http://127.0.0.1:9999

GOTRUE_JWT_SECRET=exped-local-super-secret-jwt-with-at-least-32-chars
GOTRUE_JWT_EXP=3600
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated
GOTRUE_JWT_ADMIN_ROLES=service_role
# aud do token (PostgREST não valida aud por padrão, mas mantemos consistente)
GOTRUE_JWT_AUD=authenticated

GOTRUE_SITE_URL=http://127.0.0.1:3000
GOTRUE_DISABLE_SIGNUP=false

# Permite signup/login por email+senha sem precisar confirmar email (spike local).
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true

# Caminho das migrations do auth (vêm no tarball, ao lado do binário).
GOTRUE_DB_MIGRATIONS_PATH=scripts/local-stack/bin/migrations
