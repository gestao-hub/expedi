diff --git a/cmd/serve_reuseport_unix.go b/cmd/serve_reuseport_unix.go
new file mode 100644
index 0000000..bbe1797
--- /dev/null
+++ b/cmd/serve_reuseport_unix.go
@@ -0,0 +1,27 @@
+//go:build !windows
+
+package cmd
+
+import (
+	"net"
+	"syscall"
+
+	"golang.org/x/sys/unix"
+)
+
+// reusePortListenConfig returns a net.ListenConfig that sets SO_REUSEPORT on
+// the listening socket. This allows multiple instances (or a rolling restart)
+// to bind the same port on Unix-like systems.
+func reusePortListenConfig() net.ListenConfig {
+	return net.ListenConfig{
+		Control: func(network, address string, c syscall.RawConn) error {
+			var serr error
+			if err := c.Control(func(fd uintptr) {
+				serr = unix.SetsockoptInt(int(fd), unix.SOL_SOCKET, unix.SO_REUSEPORT, 1) // #nosec G115
+			}); err != nil {
+				return err
+			}
+			return serr
+		},
+	}
+}
diff --git a/cmd/serve_reuseport_windows.go b/cmd/serve_reuseport_windows.go
new file mode 100644
index 0000000..d67da88
--- /dev/null
+++ b/cmd/serve_reuseport_windows.go
@@ -0,0 +1,14 @@
+//go:build windows
+
+package cmd
+
+import "net"
+
+// reusePortListenConfig returns a default net.ListenConfig on Windows.
+//
+// Windows has no SO_REUSEPORT socket option, so port reuse is not configured
+// here. A single GoTrue instance binding the port (the local-hub use case)
+// works without it.
+func reusePortListenConfig() net.ListenConfig {
+	return net.ListenConfig{}
+}
